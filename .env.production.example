# Agent Memory - Production Configuration
# =======================================

# Application
APP_HOST=0.0.0.0
HTTP_PORT=:8080
GRPC_PORT=:50051
SERVER_MODE=http
READ_TIMEOUT=60
WRITE_TIMEOUT=60
IDLE_TIMEOUT=120
SHUTDOWN_TIMEOUT=30

# Neo4j Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password
NEO4J_MAX_CONNS=50
NEO4J_CONN_TIMEOUT=30
NEO4J_QUERY_TIMEOUT=60

# Qdrant Configuration
QDRANT_URL=qdrant:6334
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=agent_memory_prod
VECTOR_SIZE=1536
VECTOR_PROVIDER=qdrant

# Alternative Vector Providers (uncomment to use):
# VECTOR_PROVIDER=pinecone
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_INDEX=agent-memory
# PINECONE_ENVIRONMENT=us-east-1

# VECTOR_PROVIDER=weaviate
# WEAVIATE_URL=http://weaviate:8080
# WEAVIATE_CLASS_NAME=AgentMemory

# VECTOR_PROVIDER=milvus
# MILVUS_URL=http://milvus:9091
# MILVUS_COLLECTION=agent_memory

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_DIM=1536

# Alternative LLM Providers (uncomment to use):
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LLM_PROVIDER=azure
# AZURE_API_KEY=your-azure-key
# AZURE_ENDPOINT=https://your-resource.openai.azure.com/

# Authentication
AUTH_ENABLED=true
JWT_SECRET=your-256-bit-secret-key-here
TOKEN_EXPIRY=86400
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Memory Configuration
MEMORY_PROCESSING_ENABLED=true
MEMORY_AUTO_EXTRACT_FACTS=true
MEMORY_AUTO_EXTRACT_ENTITIES=true
MEMORY_DEFAULT_IMPORTANCE=medium
MEMORY_CONFLICT_RESOLUTION=true
MEMORY_CACHE_ENABLED=true
MEMORY_CACHE_TTL=3600

# Compaction
COMPACTION_ENABLED=true
COMPACTION_INTERVAL=24h
COMPACTION_MIN_MEMORIES=100
COMPACTION_IMPORTANCE_THRESHOLD=low
COMPACTION_SUMMARIZE_THRESHOLD=1000
COMPACTION_ARCHIVE_OLD=true
COMPACTION_ARCHIVE_AFTER_DAYS=30
COMPACTION_DEDUPLICATE=true
COMPACTION_SIMILARITY_THRESHOLD=0.92

# Sync Configuration
SYNC_INTERVAL=1h
BATCH_SIZE=1000
CONTEXT_WINDOW=50
MESSAGE_BUFFER=100
BUFFER_TIMEOUT=5s

# Rate Limiting (per API key)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
